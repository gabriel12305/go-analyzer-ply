    FOR             reduce using rule 30 (print_stmt -> VARIABLE DOT VARIABLE LPAREN VARIABLE RPAREN .)
    FUNC            reduce using rule 30 (print_stmt -> VARIABLE DOT VARIABLE LPAREN VARIABLE RPAREN .)
    $end            reduce using rule 30 (print_stmt -> VARIABLE DOT VARIABLE LPAREN VARIABLE RPAREN .)
    RBRACE          reduce using rule 30 (print_stmt -> VARIABLE DOT VARIABLE LPAREN VARIABLE RPAREN .)


state 65

    (32) function_decl -> FUNC VARIABLE LPAREN RPAREN LBRACE statements . RBRACE
    (2) statements -> statements . statement
    (4) statement -> . short_var_decl
    (5) statement -> . print_stmt
    (6) statement -> . for_stmt
    (7) statement -> . function_decl
    (29) short_var_decl -> . VARIABLE DECLARE_ASSIGN expression
    (30) print_stmt -> . VARIABLE DOT VARIABLE LPAREN VARIABLE RPAREN
    (31) for_stmt -> . FOR condition LBRACE statements RBRACE
    (32) function_decl -> . FUNC VARIABLE LPAREN RPAREN LBRACE statements RBRACE

    RBRACE          shift and go to state 66
    VARIABLE        shift and go to state 8
    FOR             shift and go to state 9
    FUNC            shift and go to state 10

    statement                      shift and go to state 11
    short_var_decl                 shift and go to state 4
    print_stmt                     shift and go to state 5
    for_stmt                       shift and go to state 6
    function_decl                  shift and go to state 7

state 66

    (32) function_decl -> FUNC VARIABLE LPAREN RPAREN LBRACE statements RBRACE .

    VARIABLE        reduce using rule 32 (function_decl -> FUNC VARIABLE LPAREN RPAREN LBRACE statements RBRACE .)
    FOR             reduce using rule 32 (function_decl -> FUNC VARIABLE LPAREN RPAREN LBRACE statements RBRACE .)
    FUNC            reduce using rule 32 (function_decl -> FUNC VARIABLE LPAREN RPAREN LBRACE statements RBRACE .)
    $end            reduce using rule 32 (function_decl -> FUNC VARIABLE LPAREN RPAREN LBRACE statements RBRACE .)
    RBRACE          reduce using rule 32 (function_decl -> FUNC VARIABLE LPAREN RPAREN LBRACE statements RBRACE .)

